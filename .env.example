# ════════════════════════════════════════════════════════════
# 1) REAL ODDS + FIXTURES — The Odds API (free, no card): the-odds-api.com
#    >>> PASTE YOUR KEY ON THE NEXT LINE <<<
# ════════════════════════════════════════════════════════════
THE_ODDS_API_KEY=

# Sports that run (all four use real odds)
ENABLED_SPORTS=soccer,tennis,nba,nfl

# Books region(s): eu,uk,us,au. Keep small to save free-tier quota.
ODDS_REGIONS=eu

# The Odds API sport keys per bucket — add/remove leagues to get more/fewer games.
# Full live list: https://api.the-odds-api.com/v4/sports?apiKey=YOURKEY
ODDS_SOCCER=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_uefa_champs_league,soccer_usa_mls,soccer_brazil_campeonato
ODDS_TENNIS=tennis_atp_wimbledon,tennis_wta_wimbledon,tennis_atp_canadian_open,tennis_wta_canadian_open
ODDS_BASKETBALL=basketball_nba
ODDS_NFL=americanfootball_nfl

# ════════════════════════════════════════════════════════════
# 2) FREE AI MODELS — add whichever free keys you have. Missing keys are skipped.
#    All no-credit-card. Names shown in the app are the REAL models being called.
# ════════════════════════════════════════════════════════════
# Gemini  → aistudio.google.com  (real frontier model, free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Llama 3.3 70B → console.groq.com  (fast, free, no card)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GPT-OSS 120B → cloud.cerebras.ai  (1M tokens/day free, no card)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Claude → console.anthropic.com  (PAID — add your key when you have one)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=3001
